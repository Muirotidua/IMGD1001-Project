theme_override_fonts/normal_font = ExtResource("2_4leat")
theme_override_font_sizes/normal_font_size = 80
text = "v1.0
-Official Release
-No title

v0.6.2
-Added transition animations between levels and menus
-Added voice acting
-Added more tutorial animations

v0.6.1
-Added settings scene for audio controls
-Added control scene in settings to view control

v0.6
-Level 5, 9, and 10 finalized
-Explosion and pocket ball sound effects
-Polish & Bugfixes
-Added in Freeplay Mode

v0.5.5
-Explosion ball costs two shots, pockets return one shot
-Added arrow indicators to certain levels
-Added level 8
-Added levels 9 and 10 (beta)

v0.5.4
-Added refined sprites
-Fixed many bugs
-Added audio
-Added freeplay

v0.5.3
-Added pocket ball
-Added gates
-Added levels 6 and 7

v0.5.2
-Pause bugfixes
-Pause and SwapBall can now be closed with their respective buttons

v0.5.1
-Added Levels 4 and 5
-Added Level 6 (Beta)

v0.5
-Added Star System to Game
-Redid File / Level Directories
-Improved Internal Managers

v0.4.3
-Added Explosion Ball
-Added Level 3

v0.4.2
-Added in a Pool Stick Power Gauge
-Added in shot count visuals

v0.4.1
-Added an Eight Ball mechanic where one ball must be the last to go in

v0.4
-Added UI icons to pause, victory, and failure screens
-FIxed a bug with level select buttons where they highlight a white box when clicked

v0.3.3
-Added Victory and Failure screens when levels are finished

v0.3.2
-Added more debug settings and fixed major bugs

v0.3.1
-Added a level selection screen
-Added a pause menu

v0.3
-Added a level manager to keep track of level progress
-Revamped power gauge to increase as shot is held
-Added a shot counter for levels to be cleared under
-Added new sprites

v0.2.2
-Added a redesigned table with added flair
-Fixed a rewind and win condition bug by completely recreating how the table keeps track of its elements

v0.2.1
-Added a Rewind & Reset Mechanic to the table to redo shots
-Created a win condition

v0.2
- Added a Temporary Table with boundaries and pocket detection
-Changed file structure to use inheritence
-Constructed a template for levels to use as a base

v0.1.1
- Added a Pool Demo behind the scenes

V 0.1
-Added a WPI Splash Screen
-Added a Main Menu with interactable buttons, title, and image
-Added scrolling credits 
-Added Version History Notes

"
